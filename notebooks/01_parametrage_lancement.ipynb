                      "source":  [
                                     "# 01 - Param츾춸trage et lancement du contr츾췂le RGPD Article 9\n",
                                     "\n",
        "Notebook de pilotage local : r츾춸f츾춸rentiels, scoring, lemmatisation spaCy, synonymes automatiques et lancement du batch."
                                 ]
                  },
                  {
                      "cell_type":  "code",
                      "execution_count":  null,
                      "metadata":  {

                                   },
                      "outputs":  [

                                  ],
                      "source":  [
                                     "from pathlib import Path\n",
                                     "import sys\n",
                                     "import pandas as pd\n",
                                     "import yaml\n",
                                     "\n",
                                     "PROJECT_ROOT = Path(\"..\").resolve()\n",
                                     "SRC_DIR = PROJECT_ROOT / \"src\"\n",
                                     "if str(SRC_DIR) not in sys.path:\n",
                                     "    sys.path.insert(0, str(SRC_DIR))\n",
                                     "\n",
                                     "PDF_DIR = PROJECT_ROOT / \"input\" / \"pdf\"\n",
                                     "REFERENTIEL_DIR = PROJECT_ROOT / \"input\" / \"referentiel\"\n",
                                     "CONFIG_FILE = PROJECT_ROOT / \"config\" / \"scoring.yaml\"\n",
                                     "OUTPUT_CSV = PROJECT_ROOT / \"output\" / \"resultats_controle.csv\"\n",
                                     "OUTPUT_XLSX = PROJECT_ROOT / \"output\" / \"resultats_controle.xlsx\"\n",
                                     "\n",
                                     "print(\"Projet :\", PROJECT_ROOT)"
                                 ]
                  },
                  {
                      "cell_type":  "markdown",
                      "metadata":  {

                                   },
                      "source":  [
                                     "## 1. V츾춸rification des d츾춸pendances locales"
                                 ]
                  },
                  {
                      "cell_type":  "code",
                      "execution_count":  null,
                      "metadata":  {

                                   },
                      "outputs":  [

                                  ],
                      "source":  [
                                     "# Si spaCy ou le mod츾춷le fran츾춶ais ne sont pas install츾춸s, ex츾춸cuter dans un terminal :\n",
                                     "# pip install -r ../requirements.txt\n",
                                     "# python -m spacy download fr_core_news_md\n",
                                     "\n",
                                     "import spacy\n",
                                     "try:\n",
                                     "    nlp = spacy.load(\"fr_core_news_md\", disable=[\"ner\"])\n",
                                     "    print(\"Mod츾춷le spaCy fran츾춶ais OK : fr_core_news_md\")\n",
                                     "except OSError as exc:\n",
                                     "    raise RuntimeError(\"Mod츾춷le spaCy manquant. Ex츾춸cuter : python -m spacy download fr_core_news_md\") from exc"
                                 ]
                  },
                  {
                      "cell_type":  "markdown",
                      "metadata":  {

                                   },
                      "source":  [
                                     "## 2. V츾춸rifier les PDF et r츾춸f츾춸rentiels"
                                 ]
                  },
                  {
                      "cell_type":  "code",
                      "execution_count":  null,
                      "metadata":  {

                                   },
                      "outputs":  [

                                  ],
                      "source":  [
                                     "pdf_files = sorted(PDF_DIR.glob(\"*.pdf\"))\n",
                                     "print(f\"Nombre de PDF trouv츾춸s : {len(pdf_files)}\")\n",
                                     "for pdf in pdf_files[:20]:\n",
                                     "    print(\"-\", pdf.name)\n",
                                     "\n",
                                     "required_files = [\n",
                                     "    REFERENTIEL_DIR / \"mots_interdits.csv\",\n",
                                     "    REFERENTIEL_DIR / \"whitelist.csv\",\n",
                                     "    CONFIG_FILE,\n",
                                     "]\n",
                                     "\n",
                                     "for file in required_files:\n",
                                     "    print(file.name, \"OK\" if file.exists() else \"MANQUANT\")"
                                 ]
                  },
                  {
                      "cell_type":  "markdown",
                      "metadata":  {

                                   },
                      "source":  [
                                     "## 3. Charger les r츾춸f츾춸rentiels m츾춸tier"
                                 ]
                  },
                  {
                      "cell_type":  "code",
                      "execution_count":  null,
                      "metadata":  {

                                   },
                      "outputs":  [

                                  ],
                      "source":  [
                                     "mots_interdits = pd.read_csv(REFERENTIEL_DIR / \"mots_interdits.csv\", encoding=\"utf-8\")\n",
                                     "whitelist = pd.read_csv(REFERENTIEL_DIR / \"whitelist.csv\", encoding=\"utf-8\")\n",
                                     "\n",
                                     "display(mots_interdits.head(20))\n",
                                     "display(whitelist.head(20))"
                                 ]
                  },
                  {
                      "cell_type":  "markdown",
                      "metadata":  {

                                   },
                      "source":  [
                                     "## 4. Param츾춸trer le scoring"
                                 ]
                  },
                  {
                      "cell_type":  "code",
                      "execution_count":  null,
                      "metadata":  {

                                   },
                      "outputs":  [

                                  ],
                      "source":  [
                                     "with open(CONFIG_FILE, \"r\", encoding=\"utf-8\") as f:\n",
                                     "    config = yaml.safe_load(f)\n",
                                     "\n",
                                     "# Param츾춷tres modifiables pour ce lancement\n",
                                     "config[\"detection\"][\"activer_lemmatisation\"] = True\n",
                                     "config[\"detection\"][\"activer_synonymes_automatiques\"] = True\n",
                                     "config[\"detection\"][\"activer_mots_proches\"] = True\n",
                                     "config[\"detection\"][\"seuil_synonyme_automatique\"] = 0.72\n",
                                     "config[\"detection\"][\"seuil_similarite_orthographique\"] = 88\n",
                                     "config[\"score\"][\"synonyme_automatique\"] = 80\n",
                                     "config[\"detection\"][\"taille_contexte_mots\"] = 12\n",
                                     "\n",
                                     "config"
                                 ]
                  },
                  {
                      "cell_type":  "markdown",
                      "metadata":  {

                                   },
                      "source":  [
                                     "## 5. Test rapide de lemmatisation"
                                 ]
                  },
                  {
                      "cell_type":  "code",
                      "execution_count":  null,
                      "metadata":  {

                                   },
                      "outputs":  [

                                  ],
                      "source":  [
                                     "from lemmatizer import lemmatize_text\n",
                                     "\n",
                                     "texte_test = \"Le client indique 츾춹tre malade et suivre un traitement.\"\n",
                                     "tokens = lemmatize_text(texte_test)\n",
                                     "pd.DataFrame(tokens)"
                                 ]
                  },
                  {
                      "cell_type":  "markdown",
                      "metadata":  {

                                   },
                      "source":  [
                                     "## 6. Lancer le traitement"
                                 ]
                  },
                  {
                      "cell_type":  "code",
                      "execution_count":  null,
                      "metadata":  {

                                   },
                      "outputs":  [

                                  ],
                      "source":  [
                                     "import importlib\n",
                                     "import extract_pdf\n",
                                     "import load_referential\n",
                                     "import detection\n",
                                     "import export_results\n",
                                     "\n",
                                     "# Recharge les modules si le kernel Jupyter avait garde une ancienne version en memoire.\n",
                                     "importlib.reload(extract_pdf)\n",
                                     "importlib.reload(load_referential)\n",
                                     "importlib.reload(detection)\n",
                                     "importlib.reload(export_results)\n",
                                     "\n",
                                     "from extract_pdf import extract_text_from_pdf\n",
                                     "from load_referential import load_referentials\n",
                                     "from detection import analyze_document\n",
                                     "from export_results import export_results\n",
                                     "\n",
                                     "referentials = load_referentials(REFERENTIEL_DIR)\n",
                                     "results = []\n",
                                     "\n",
                                     "for pdf_path in sorted(PDF_DIR.glob(\"*.pdf\")):\n",
                                     "    print(\"Analyse :\", pdf_path.name)\n",
                                     "    text_by_page = extract_text_from_pdf(pdf_path)\n",
                                     "    results.extend(analyze_document(pdf_path, text_by_page, referentials, config))\n",
                                     "\n",
                                     "OUTPUT_CSV.parent.mkdir(parents=True, exist_ok=True)\n",
                                     "export_results(results, OUTPUT_CSV, OUTPUT_XLSX)\n",
                                     "print(\"CSV g츾춸n츾춸r츾춸 :\", OUTPUT_CSV)\n",
                                     "print(\"Excel g츾춸n츾춸r츾춸 :\", OUTPUT_XLSX)"
                                 ]
                  },
                  {
                      "cell_type":  "markdown",
                      "metadata":  {

                                   },
                      "source":  [
